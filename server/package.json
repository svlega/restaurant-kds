{
  "name": "@cordial-kds/server",
  "version": "1.0.0",
  "description": "Express API server for Cordial KDS",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --coverage",
    "lint": "eslint src tests --ext .js"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.5",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/app.js",
      "!src/routes/**",
      "!src/services/whatsappService.js",
      "!src/utils/logger.js",
      "!src/utils/orderCounter.js",
      "!src/database.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 55
      }
    }
  }
}
